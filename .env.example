# --- Pear Protocol API connection ---
# Production base URL for the engine you want to drive.
# Hyperliquid v2 (documented):     https://hl-v2.pearprotocol.io
# Pear Pro x Lighter:              <ask the Pear team for the Lighter engine base URL>
PEAR_API_BASE_URL=https://hl-v2.pearprotocol.io

# clientId is required on every auth request.
#  - Individual traders:                       APITRADER
#  - Products built on top of Pear (partners): your own client id (request from Pear)
PEAR_CLIENT_ID=APITRADER

# Your wallet address (the trading account identity).
PEAR_ADDRESS=0xYourWalletAddress

# Long-lived API key created via POST /api-keys (preferred for bots/agents).
# Leave empty to use a pre-fetched access token instead.
PEAR_API_KEY=

# Optional: skip the auth flow and use an already-issued JWT access token.
PEAR_ACCESS_TOKEN=

# --- Safety rails ---
# When true, the server refuses every order-placing / position-mutating tool.
# Recommended default for demos and for any agent you do not fully trust.
PEAR_READ_ONLY=true

# --- Background rebalance monitor (npm run monitor) ---
# Poll interval in ms (min 5000). 300000 = 5 minutes.
PEAR_POLL_INTERVAL_MS=300000
# Recommend a rebalance when any leg's weight drifts this far from target (0.05 = 5%).
PEAR_DRIFT_THRESHOLD=0.05
# Watch a single position; leave empty to watch all open positions.
PEAR_POSITION_ID=
# If true AND PEAR_READ_ONLY=false, the monitor executes rebalances itself.
# If false (default), it only notifies and you approve via chat ("rebalance <id>").
PEAR_AUTO_REBALANCE=false
