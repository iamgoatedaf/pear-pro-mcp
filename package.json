{
  "name": "pear-pro-mcp",
  "version": "0.1.0",
  "description": "Model Context Protocol server for Pear Protocol — pair & basket trading (Pear Pro x Lighter / Hyperliquid)",
  "type": "module",
  "bin": {
    "pear-pro-mcp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "monitor": "node dist/monitor.js",
    "monitor:dev": "tsx src/monitor.ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "pear-protocol",
    "pair-trading",
    "lighter",
    "hyperliquid",
    "trading"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.18.0",
    "dotenv": "^17.4.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  }
}
